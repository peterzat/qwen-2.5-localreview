#!/usr/bin/env bash
set -euo pipefail

# Pre-push hook: runs fast tests (no GPU required, < 2 seconds).
# The GPU inference test in test-review.sh auto-skips when unavailable.

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

echo "pre-push: running tests..."

"${REPO_DIR}/tests/test-call-local.sh"
"${REPO_DIR}/tests/test-review.sh"

echo "pre-push: all tests passed"
