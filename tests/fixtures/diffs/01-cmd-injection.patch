+"""Small helper to run user-supplied build commands."""
+import os
+import sys
+
+
+def run_build(target: str) -> int:
+    """Invoke the build script for the given target."""
+    cmd = f"./build.sh {target}"
+    return os.system(cmd)
+
+
+def main() -> int:
+    target = sys.argv[1] if len(sys.argv) > 1 else "all"
+    return run_build(target)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
