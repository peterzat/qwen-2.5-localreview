+struct Message {
+    std::string type;
+    std::string payload;
+};
+
+class Dispatcher {
+public:
+    using Handler = std::function<void(std::string)>;
+
+    void register_handler(const std::string& type, Handler h) {
+        handlers_[type] = std::move(h);
